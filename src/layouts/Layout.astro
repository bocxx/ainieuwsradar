---
import '../styles/main.css';
import { Font } from 'astro:assets';
import { ClientRouter } from 'astro:transitions';
const {
  title = 'AI Nieuws Radar',
  description = '',
  ogType = 'website',
  image = '/og-image.png',
  noindex = false,
} = Astro.props;
const year = new Date().getFullYear();
const site = Astro.site ?? new URL('https://ainieuwsradar.nl');
const canonical = new URL(Astro.url.pathname.replace(/\/$/, '') || '/', site).href;
const ogImage = new URL(image, site).href;
const jsonld = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'AI Nieuws Radar',
  url: site.href,
  inLanguage: 'nl-NL',
  description:
    'Signaalradar voor AI: opkomende trends, zwakke signalen en een bewezen track record, gemeten over 1000+ bronnen.',
  publisher: { '@type': 'Organization', name: 'AI Nieuws Radar' },
};
---
<!doctype html>
<html lang="nl" data-theme="light">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  {/* Thema vóór de eerste paint zetten — voorkomt een licht→donker-flits bij elke
      navigatie. Her-toepassen na een view-transition-swap. */}
  <script is:inline>
    (() => { try { const t = localStorage.getItem('air-theme'); if (t) document.documentElement.setAttribute('data-theme', t); } catch (e) {} })();
    document.addEventListener('astro:after-swap', () => { try { const t = localStorage.getItem('air-theme'); if (t) document.documentElement.setAttribute('data-theme', t); } catch (e) {} });
  </script>
  <ClientRouter />
  <title>{title}</title>
  <Font cssVariable="--font-boldonse" preload />
  <Font cssVariable="--font-geist" />
  <Font cssVariable="--font-jetbrains-mono" />
  <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
  <meta name="description" content={description} />
  <link rel="canonical" href={canonical} />
  {noindex && <meta name="robots" content="noindex, nofollow" />}
  <meta name="theme-color" content="#fcfaf7" />

  <meta property="og:type" content={ogType} />
  <meta property="og:site_name" content="AI Nieuws Radar" />
  <meta property="og:locale" content="nl_NL" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonical} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImage} />

  <link rel="sitemap" href="/sitemap-index.xml" />
  <script type="application/ld+json" set:html={JSON.stringify(jsonld)} />

  {/* Umami Analytics — vul data-website-id met het Website ID van deze site
      (cloud.umami.is/settings/websites). Eén Umami-account/abonnement, per site
      een eigen Website ID. View-Transitions-aware. Leeg = geen tracking. */}
  <link rel="preconnect" href="https://cloud.umami.is" crossorigin />
  <link rel="dns-prefetch" href="https://cloud.umami.is" />
  <script defer src="https://cloud.umami.is/script.js" data-website-id="9dad3643-f050-42a8-8d8a-64a868ad15c9" data-auto-track="false"></script>
  <script is:inline>{`
    (function(){
      function t(){if(window.umami&&typeof window.umami.track==='function')window.umami.track();}
      if(document.readyState!=='loading')t();else document.addEventListener('DOMContentLoaded',t);
      document.addEventListener('astro:page-load',t);
    })();
  `}</script>
  <script is:inline>
    // Umami custom events (netwerk-breed, juni 2026): ai-referral (AEO),
    // cross-domain-click, source-link-click, tab-switch, audio-play, read-depth.
    // Rauwe JS (geen template-wrapper). window.umami komt van het externe script.
    (function () {
      var CONTENT_SEL = '.article__content, .prose, .content-col';
      var NET = { 'hetlaatsteainieuws.nl':1,'debesteaitools.nl':1,'aiplatformmkb.nl':1,'ainieuwsradar.nl':1,'feedzzz.online':1,'whotofollow.online':1 };
      function norm(h){return (h||'').toLowerCase().replace(/^www\./,'');}
      function slugOf(){var p=location.pathname.replace(/\/+$/,'');return p.split('/').filter(Boolean).pop()||'';}
      function track(name,data){try{if(window.umami&&window.umami.track)window.umami.track(name,data);}catch(e){}}
      function trackReady(name,data){function go(){if(window.umami&&window.umami.track){window.umami.track(name,data);return true;}return false;}if(go())return;var n=0;var iv=setInterval(function(){if(go()||++n>100)clearInterval(iv);},50);}
      var ENGINES={'chatgpt.com':'chatgpt','chat.openai.com':'chatgpt','openai.com':'chatgpt','perplexity.ai':'perplexity','gemini.google.com':'gemini','copilot.microsoft.com':'copilot','m365.cloud.microsoft':'copilot','claude.ai':'claude','you.com':'you','phind.com':'phind','grok.com':'grok','x.ai':'grok','mistral.ai':'mistral','chat.mistral.ai':'mistral','poe.com':'poe','deepseek.com':'deepseek','chat.deepseek.com':'deepseek','meta.ai':'meta'};
      function engineFromValue(v){if(!v)return null;v=v.toLowerCase();if(ENGINES[norm(v)])return ENGINES[norm(v)];var keys=['chatgpt','openai','perplexity','gemini','copilot','claude','phind','grok','mistral','deepseek','meta.ai'];for(var i=0;i<keys.length;i++){if(v.indexOf(keys[i])!==-1)return keys[i]==='meta.ai'?'meta':keys[i].replace('openai','chatgpt');}return null;}
      (function(){var src=null;try{var p=new URLSearchParams(location.search);src=p.get('utm_source')||p.get('ref')||p.get('source');}catch(e){}var eng=engineFromValue(src),via='param';if(!eng){var ref=document.referrer||'';if(ref){try{var host=norm(new URL(ref).hostname);if(host&&host!==norm(location.hostname)&&ENGINES[host]){eng=ENGINES[host];via='referrer';}}catch(e){}}}if(eng)trackReady('ai-referral',{engine:eng,via:via,landing:location.pathname+location.search});})();
      document.addEventListener('click',function(e){var t=e.target;if(!t||!t.closest)return;var tab=t.closest('[data-tab], [data-tab-top]');if(tab){var which=tab.getAttribute('data-tab')||tab.getAttribute('data-tab-top');if(which)track('tab-switch',{tab:which,page:location.pathname});}var a=t.closest('a[href]');if(!a)return;var href=a.getAttribute('href')||'';if(!/^https?:\/\//i.test(href))return;var h;try{h=norm(new URL(href).hostname);}catch(_){return;}if(!h||h===norm(location.hostname))return;if(NET[h])track('cross-domain-click',{to:h,href:href,from:location.pathname});else if(a.closest(CONTENT_SEL))track('source-link-click',{host:h,href:href,from:location.pathname});},true);
      document.addEventListener('play',function(e){if(e.target&&e.target.tagName==='AUDIO')track('audio-play',{slug:slugOf()});},true);
      var fired={};function checkDepth(){var el=document.querySelector(CONTENT_SEL);if(!el)return;var total=el.offsetHeight;if(total<=0)return;var rect=el.getBoundingClientRect();var pct=Math.min(total,Math.max(0,window.innerHeight-rect.top))/total;var marks=[25,50,75,100];for(var i=0;i<marks.length;i++){var m=marks[i];if(pct>=m/100&&!fired[m]){fired[m]=1;track('read-depth',{pct:m,slug:slugOf()});}}}
      var ticking=false;window.addEventListener('scroll',function(){if(ticking)return;ticking=true;requestAnimationFrame(function(){checkDepth();ticking=false;});},{passive:true});
      function resetForPage(){fired={};checkDepth();}
      if(document.readyState!=='loading')resetForPage();else document.addEventListener('DOMContentLoaded',resetForPage);
      document.addEventListener('astro:page-load',resetForPage);
    })();
  </script>
</head>
<body>
  <a href="#main" class="skip-link">Naar de hoofdinhoud</a>

  <header class="hdr" transition:persist>
    <div class="hdr__inner">
      <a href="/" class="logo" aria-label="ai / radar — homepage">
        <span class="logo__a">ai</span><span class="logo__slash">/</span><span class="logo__b">radar</span>
      </a>
      <input type="checkbox" id="navtoggle" class="navtoggle" hidden />
      <nav class="hdr__nav" aria-label="Hoofdnavigatie">
        <a href="/radar">Archief</a>
        <a href="/trends">Trends</a>
        <a href="/hype">Hype</a>
        <a href="/ai-in-nederland">AI in NL</a>
        <a href="/wetenschap">Wetenschap</a>
        <a href="/methode">Methode</a>
        <a href="/voorspellingen">Voorspellingen</a>
        <a href="/track-record">Track record</a>
      </nav>
      <label for="navtoggle" class="hamburger" aria-label="Menu openen/sluiten">
        <span></span><span></span><span></span>
      </label>
      <button id="theme-toggle" class="hdr__theme" type="button" aria-label="Wissel thema">
        <span class="hdr__theme-dot"></span>
      </button>
    </div>
  </header>

  <slot />

  <footer class="ftr">
    <div class="ftr__inner">
      <div>
        <a href="/" class="logo logo--sm" aria-label="ai / radar">
          <span class="logo__a">ai</span><span class="logo__slash">/</span><span class="logo__b">radar</span>
        </a>
        <p class="ftr__tag">Signaalradar voor AI. Zie wat doorbreekt — voor het nieuws wordt.</p>
        <nav class="ftr__links" aria-label="Footer">
          <a href="/radar">Radar-archief</a>
          <a href="/trends">Trends A–Z</a>
          <a href="/hype">Hype-o-Meter</a>
          <a href="/ai-in-nederland">AI in Nederland</a>
          <a href="/wetenschap">Breaking Science</a>
          <a href="/methode">Methode</a>
          <a href="/voorspellingen">Open voorspellingen</a>
          <a href="/track-record">Track record</a>
        </nav>
      </div>
      <p class="ftr__net">
        Onderdeel van het netwerk van
        <a href="https://hetlaatsteainieuws.nl">hetlaatsteainieuws.nl</a> &amp;
        <a href="https://debesteaitools.nl">debesteaitools.nl</a>.
      </p>
      <p class="ftr__copy">© {year} ai / radar · gevoed door NewsFlux</p>
    </div>
  </footer>

  <script is:inline>
    (() => {
      const root = document.documentElement, KEY = 'air-theme';
      const bind = () => {
        const btn = document.getElementById('theme-toggle');
        if (!btn || btn.dataset.bound) return;
        btn.dataset.bound = '1';
        btn.addEventListener('click', () => {
          const next = root.getAttribute('data-theme') === 'light' ? 'dark' : 'light';
          root.setAttribute('data-theme', next);
          try { localStorage.setItem(KEY, next); } catch (e) {}
        });
      };
      bind();
      document.addEventListener('astro:page-load', bind);
    })();
  </script>

  <style>
    .skip-link { position:absolute; left:-9999px; top:0; background:var(--primary-bright); color:var(--text-inverse); padding:var(--space-2) var(--space-4); border-radius:var(--radius-md); z-index:var(--z-max); }
    .skip-link:focus { left:var(--space-4); top:var(--space-4); }

    .hdr { position:sticky; top:0; z-index:var(--z-sticky); background:var(--bg-glass); -webkit-backdrop-filter:blur(14px); backdrop-filter:blur(14px); border-bottom:1px solid var(--border-subtle); }
    .hdr__inner { position:relative; max-width:var(--container-xwide); margin:0 auto; padding:var(--space-3) var(--space-6); display:flex; align-items:center; gap:var(--space-6); }
    .hdr__nav { margin-left:auto; display:flex; gap:var(--space-5); }
    .hdr__nav a { font-family:var(--font-mono); font-size:var(--text-2xs); text-transform:uppercase; letter-spacing:var(--tracking-wide); color:var(--text-muted); }
    .hdr__nav a:hover { color:var(--primary-bright); }
    .hamburger { display:none; flex-direction:column; justify-content:center; gap:4px; width:34px; height:28px; cursor:pointer; }
    .hamburger span { display:block; height:2px; width:20px; background:var(--text-primary); border-radius:2px; transition:transform var(--transition-base); }
    .hdr__theme { width:34px; height:20px; border:1px solid var(--border-strong); border-radius:var(--radius-full); display:inline-flex; align-items:center; padding:0 2px; }
    .hdr__theme-dot { width:14px; height:14px; border-radius:var(--radius-full); background:var(--primary-bright); transition:transform var(--transition-base); }
    html[data-theme="light"] .hdr__theme-dot { transform:translateX(0); }
    html:not([data-theme="light"]) .hdr__theme-dot { transform:translateX(14px); }
    @media (max-width:48em){
      .hamburger { display:flex; margin-left:auto; }
      .hdr__nav {
        display:none; position:absolute; top:100%; left:0; right:0; margin:0;
        flex-direction:column; gap:0;
        background:var(--bg-surface); border-bottom:1px solid var(--border-subtle);
        padding:var(--space-2) var(--space-6) var(--space-4);
        box-shadow:var(--shadow-md);
      }
      .navtoggle:checked ~ .hdr__nav { display:flex; }
      .hdr__nav a { padding:var(--space-3) 0; font-size:var(--text-xs); border-bottom:1px solid var(--border-subtle); }
    }

    .logo { display:inline-flex; align-items:baseline; gap:1px; font-family:var(--font-logo); font-size:var(--text-lg); color:var(--text-primary); letter-spacing:var(--tracking-tight); }
    .logo__slash { color:var(--primary-bright); margin:0 2px; }
    .logo__b { color:var(--text-primary); }
    .logo--sm { font-size:var(--text-base); }

    .ftr { margin-top:var(--space-24); border-top:1px solid var(--border-subtle); background:var(--bg-surface); }
    .ftr__inner { max-width:var(--container-xwide); margin:0 auto; padding:var(--space-12) var(--space-6); display:grid; gap:var(--space-4); }
    .ftr__tag { font-size:var(--text-sm); color:var(--text-secondary); margin-top:var(--space-2); max-width:42ch; }
    .ftr__links { display:flex; flex-wrap:wrap; gap:var(--space-4); margin-top:var(--space-4); }
    .ftr__links a { font-family:var(--font-mono); font-size:var(--text-2xs); text-transform:uppercase; letter-spacing:var(--tracking-wide); color:var(--text-muted); }
    .ftr__links a:hover { color:var(--primary-bright); }
    .ftr__net { font-size:var(--text-sm); color:var(--text-secondary); }
    .ftr__copy { font-family:var(--font-mono); font-size:var(--text-2xs); text-transform:uppercase; letter-spacing:var(--tracking-wide); color:var(--text-muted); }
  </style>
</body>
</html>
