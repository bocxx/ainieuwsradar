---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Niet gevonden — AI Nieuws Radar" description="Deze pagina bestaat niet (meer)." noindex={true}>
  <main id="main" class="nf">
    <p class="kicker">404</p>
    <h1>Buiten bereik van de radar</h1>
    <p>Deze pagina vonden we niet. Spring terug naar de <a href="/">live radar</a> of het <a href="/radar">archief</a>.</p>
  </main>
  <style>
    .nf { max-width:var(--container-narrow); margin:0 auto; padding:var(--space-24) var(--space-6); text-align:center; }
    .kicker { font-family:var(--font-mono); color:var(--primary-bright); letter-spacing:var(--tracking-widest); }
    .nf h1 { font-family:var(--font-display); font-size:var(--text-4xl); font-weight:var(--font-regular); margin:var(--space-3) 0; }
    .nf p { color:var(--text-secondary); }
  </style>
</Layout>
